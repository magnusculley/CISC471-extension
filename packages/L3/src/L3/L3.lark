PROGRAM.2   : "l3"
LET.2       : "let"
LETREC.2    : "letrec"
LAMBDA.2    : "\\" | "lambda" | "λ"
IF.2        : "if"
ALLOCATE.2  : "allocate"
LOAD.2      : "load"
STORE.2     : "store"
BEGIN.2     : "begin"

//doesn't really need to be token because it's only used in one place, but it makes the grammar more readable, and potentially could be used in more places in the future, so I think it's worth it
OPERATOR : "+" | "-" | "*" 
COMPARATOR : "<" | "=="

IDENTIFIER  : /[a-zA-Z_][a-zA-Z0-9_]*/
INTEGER      : /-?(?:0|[1-9][0-9]*)/
FLOAT       : /-?(?:0|[1-9][0-9]*)\.[0-9]+/

NUMBER      : immediate | float

BOOLEAN     : "true" | "false"  


EVALUATE    : COMPARATOR NUMBER NUMBER | COMPARATOR boolean boolean | boolean


%import common.WS
%ignore WS
%ignore /;[^\n]*/